generator client {
  provider = "prisma-client-js"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Game {
  id           String     @id @default(uuid())
  createdAt    DateTime   @default(now())
  result       Result
  pgn          String
  modelVersion String
  status       GameStatus @default(fresh)

  moves Move[]
}

model Move {
  id     String @id @default(uuid())
  gameId String
  game   Game   @relation(fields: [gameId], references: [id])

  moveIndex Int
  fen       String
  moveUci   String

  player Player
  reward Float? // Filled after game ends
}

enum Player {
  white
  black
}

enum Result {
  win
  loss
  draw
}

enum GameStatus {
  fresh
  completed
  archived
  bad
}
